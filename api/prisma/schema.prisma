generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

//
// ENUMS
//

enum UserRole {
  SYSTEM_ADMIN
  CUSTOMER_ADMIN
  CUSTOMER_USER
  CUSTOMER
}

enum DeviceType {
  CONTROLLER
  SENSOR
  GATEWAY
}

enum DeviceProvisioningStatus {
  PENDING
  ACTIVE
  DISABLED
}

enum CommandStatus {
  PENDING
  SENT
  ACKNOWLEDGED
  FAILED
  TIMEOUT
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertType {
  OFFLINE
  LOW_BATTERY
  LOW_SIGNAL
  LEAK_DETECTED
  DEVICE_ERROR
}

//
// TENANTS
//

model Tenant {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  slug         String   @unique
  plan         String   @default("starter")
  useSubRoles  Boolean  @default(false)

  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())

  users     User[]
  farms     Farm[]
  devices   Device[]
  commands  Command[]
  alerts    Alert[]
  schedules Schedule[]
  fields    Field[]

  @@map("tenants")
}

//
// USERS
//

model User {
  id           String    @id @default(uuid()) @db.Uuid

  tenantId     String    @db.Uuid
  tenant       Tenant    @relation(fields: [tenantId], references: [id])

  name         String?
  email        String    @unique

  passwordHash String

  role         UserRole

  isActive     Boolean   @default(true)

  lastLoginAt  DateTime?

  createdAt    DateTime  @default(now())

  commands     Command[]
  schedules    Schedule[]

  @@index([tenantId])
  @@map("users")
}

//
// FARMS
//

model Farm {
  id         String    @id @default(uuid()) @db.Uuid

  tenantId   String    @db.Uuid
  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  name       String

  address    String?

  latitude   Float?
  longitude  Float?

  timezone   String    @default("Asia/Kolkata")

  createdAt  DateTime  @default(now())

  devices    Device[]

  @@index([tenantId])
  @@map("farms")
}

//
// DEVICES
//

model Device {
  id                  String   @id @default(uuid()) @db.Uuid

  tenantId            String   @db.Uuid
  tenant              Tenant   @relation(fields: [tenantId], references: [id])

  farmId              String?  @db.Uuid
  farm                Farm?    @relation(fields: [farmId], references: [id])

  deviceUid           String   @unique

  name                String?

  type                DeviceType

  firmwareVersion     String?
  hardwareVersion     String?

  secretKey           String

  mqttUsername        String?
  mqttPasswordHash    String?

  provisioningStatus  DeviceProvisioningStatus  @default(PENDING)

  installedAt         DateTime?

  lastSeenAt          DateTime?

  createdAt           DateTime @default(now())

  status              DeviceStatus?

  telemetry           Telemetry[]
  commands            Command[]
  alerts              Alert[]
  schedules           Schedule[]
  events              DeviceEvent[]

  @@index([tenantId])
  @@index([farmId])
  @@map("devices")
}

//
// DEVICE STATUS
// realtime current state
//

model DeviceStatus {
  deviceId          String   @id @db.Uuid

  device            Device   @relation(fields: [deviceId], references: [id])

  online            Boolean  @default(false)

  pumpState         Boolean  @default(false)

  valveState        Boolean  @default(false)

  moistureLevel     Decimal? @db.Decimal(5, 2)

  batteryLevel      Int?

  signalStrength    Int?

  lastTelemetryAt   DateTime?

  updatedAt         DateTime @updatedAt

  @@map("device_status")
}

//
// TELEMETRY
// TimescaleDB hypertable
//

model Telemetry {
  time              DateTime

  tenantId          String   @db.Uuid

  deviceId          String   @db.Uuid
  device            Device   @relation(fields: [deviceId], references: [id])

  moistureLevel     Decimal? @db.Decimal(5, 2)

  batteryLevel      Int?

  signalStrength    Int?

  temperature       Decimal? @db.Decimal(5, 2)

  humidity          Decimal? @db.Decimal(5, 2)

  payload           Json?

  @@id([deviceId, time])

  @@index([deviceId, time(sort: Desc)])

  @@map("telemetry")
}

//
// COMMANDS
//

model Command {
  id               String         @id @default(uuid()) @db.Uuid

  tenantId         String         @db.Uuid
  tenant           Tenant         @relation(fields: [tenantId], references: [id])

  deviceId         String         @db.Uuid
  device           Device         @relation(fields: [deviceId], references: [id])

  commandType      String

  payload          Json?

  status           CommandStatus  @default(PENDING)

  retryCount       Int            @default(0)

  sentById         String?        @db.Uuid
  sentBy           User?          @relation(fields: [sentById], references: [id])

  sentAt           DateTime       @default(now())

  acknowledgedAt   DateTime?

  @@index([tenantId])
  @@index([deviceId])
  @@index([status])

  @@map("commands")
}

//
// ALERTS
//

model Alert {
  id              String         @id @default(uuid()) @db.Uuid

  tenantId        String         @db.Uuid
  tenant          Tenant         @relation(fields: [tenantId], references: [id])

  deviceId        String?        @db.Uuid
  device          Device?        @relation(fields: [deviceId], references: [id])

  type            AlertType

  severity        AlertSeverity

  title           String

  message         String

  metadata        Json?

  resolved        Boolean        @default(false)

  resolvedAt      DateTime?

  createdAt       DateTime       @default(now())

  @@index([tenantId])
  @@index([deviceId])
  @@index([resolved])

  @@map("alerts")
}

//
// SCHEDULES
//

model Schedule {
  id                String    @id @default(uuid()) @db.Uuid

  tenantId          String    @db.Uuid
  tenant            Tenant    @relation(fields: [tenantId], references: [id])

  deviceId          String    @db.Uuid
  device            Device    @relation(fields: [deviceId], references: [id])

  cronExpression    String

  timezone          String    @default("Asia/Kolkata")

  commandType       String

  payload           Json?

  enabled           Boolean   @default(true)

  createdById       String?   @db.Uuid
  createdBy         User?     @relation(fields: [createdById], references: [id])

  createdAt         DateTime  @default(now())

  @@index([tenantId])
  @@index([deviceId])

  @@map("schedules")
}

//
// DEVICE EVENTS
// TimescaleDB hypertable
//

model DeviceEvent {
  time          DateTime

  tenantId      String   @db.Uuid

  deviceId      String   @db.Uuid
  device        Device   @relation(fields: [deviceId], references: [id])

  eventType     String

  payload       Json?

  @@id([deviceId, time])

  @@index([deviceId, time(sort: Desc)])

  @@map("device_events")
}

//
// FIELDS
//

model Field {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  tenantId   String   @db.Uuid
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  zones      Zone[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("fields")
}

//
// ZONES
//

model Zone {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  fieldId   String   @db.Uuid
  field     Field    @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  valves    Valve[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fieldId])
  @@map("zones")
}

//
// VALVES
//

model Valve {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  zoneId    String   @db.Uuid
  zone      Zone     @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([zoneId])
  @@map("valves")
}
