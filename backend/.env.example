# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000,http://localhost:8080
JWT_SECRET=change-this-long-random-secret
JWT_EXPIRES_IN=7d

# MySQL / Prisma v7
DATABASE_URL="mysql://root:Welcome123!@localhost:3306/dripirrigation"
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=drip
DATABASE_PASSWORD=dripPassword
DATABASE_NAME=dripIrrigation
DATABASE_CONNECTION_LIMIT=5

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MQTT Broker
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=drip-api-server

# Command behavior
MANUAL_COMMAND_EXPIRY_MINUTES=30
SCHEDULE_COMMAND_EXPIRY_MINUTES=10
MAX_COMMAND_RETRIES=3
ZONE_VALVE_DELAY_SECONDS=2
HEARTBEAT_OFFLINE_THRESHOLD_SECONDS=120
